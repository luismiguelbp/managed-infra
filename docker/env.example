# Copy to .env on each Pi and set the REQUIRED secrets before starting the stack.
# Ansible creates this file on first deploy; edit secrets locally on the host.

# Leave empty — Ansible sets this from inventory_hostname on deploy (container name prefix).
COMPOSE_PROJECT_NAME=
COMPOSE_PATH_SEPARATOR=,
COMPOSE_FILE=compose.yml,compose-node-red.yml,compose-mosquitto.yml

DOCKER_PATH=/opt/docker
DOCKER_TZ=Europe/Madrid
DOCKER_UID=1000
DOCKER_GID=1000

# REQUIRED — generate and set on each Pi (do not commit real values)
NODE_RED_CREDENTIAL_SECRET=
MQTT_USER=
MQTT_PASSWORD=

# Optional full stack example.
# COMPOSE_FILE=compose.yml,compose-portainer.yml,compose-node-red.yml,compose-mosquitto.yml,compose-postgresql.yml,compose-grafana.yml
# PostgreSQL + Grafana stack (edge-node-3 / site-c)
# COMPOSE_FILE=compose.yml,compose-postgresql.yml,compose-grafana.yml
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=automation
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=
GRAFANA_INSTALL_PLUGINS=
