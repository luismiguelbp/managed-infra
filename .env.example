# Copy to .env and set paths for your machine. .env is gitignored.
#
# Control-machine only (your Mac). Edge stack vars (MQTT, Node-RED, etc.) are in
# docker/env.example and are deployed to /opt/docker/.env on each Pi.

# Required for bin/ansible-* and infra-* scripts.
# Path to managed-infra-config-src (real inventory and docker/ configs).
MANAGED_INFRA_CONFIG_SRC=/Users/you/Developer/projects/managed-infra-config-src
# Required for bin/infra-backup-edge-stack.
# User-defined mirror root on this Mac. Keep backups outside git.
MANAGED_INFRA_BACKUP_DEST=/Users/you/Developer/projects/managed-infra-backup
