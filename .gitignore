.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.coverage
htmlcov/
.pytest_cache/
.DS_Store

# Secrets and runtime credentials (restore from backup locally)
.env
**/.env
docker/data/mosquitto/config/passwords_file

# Edge stack runtime data (local Mac or Pi; not shipped from repo)
docker/data/mosquitto/data/*
!docker/data/mosquitto/data/.gitkeep
docker/data/mosquitto/log/*
!docker/data/mosquitto/log/.gitkeep
docker/data/node-red/data/*
!docker/data/node-red/data/.gitkeep
!docker/data/node-red/data/settings.js
docker/data/postgresql/data/*
!docker/data/postgresql/data/.gitkeep
docker/data/grafana/data/*
!docker/data/grafana/data/.gitkeep
docker/data/grafana/provisioning/*
!docker/data/grafana/provisioning/.gitkeep
